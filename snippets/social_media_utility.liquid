{% style %}
  .custom-menu-drawer__utility-links{
    z-index: 20;
    position: fixed;
    bottom: 0px;
    left: 0;
    width: 100%;
    margin: 0;
    padding: 25px 24px 10.9%;
    background-color: rgb(244, 236, 208);
    max-height: 200px;
  }

  .custom-menu-drawer__utility-links .list.list-social.list-unstyled {
    display: flex;
    justify-content: space-between;
    width: 100%;
    max-height: 50px;
  }
  .custom-menu-drawer__utility-links .list.list-social.list-unstyled svg {
    color: #482f8f;
  }
{% endstyle %}