<script>

    // Logic is used for account page.
    // In below logic, we redirect to delivery address tab, in case of:
    // a) on click of "mark as default" button  in "addresses" in account page
    // b) on click of edit submit button from "edit address" form.
    
    {% if template.name == 'addresses' or  template.name == 'account'  %}
  
      {% if template.name == 'addresses' %}
        window.location.href = `/account#deliveryaddress`;
      {% endif %}
      
      let redirectToAddressAfterMarkDefault = sessionStorage.getItem('redirectToDeliveryAddressTab');
      if(redirectToAddressAfterMarkDefault !== null){
        if(redirectToAddressAfterMarkDefault === 'true'){   
          if(window.location.href === '{{ shop.url }}/account'){
            sessionStorage.setItem('redirectToDeliveryAddressTab','false');
            window.location.href = '/account#deliveryaddress';        
          }
        }
      }

      let redirectToAddressTabFromEdit = sessionStorage.getItem('redirectToAddressTabFromEdit');
      if(redirectToAddressTabFromEdit !== null){
          if(redirectToAddressTabFromEdit === 'true'){   
          if(window.location.href === '{{ shop.url }}/account'){
            sessionStorage.setItem('redirectToAddressTabFromEdit','false');
            window.location.href = '/account#deliveryaddress';        
          }
        }
      }
      
    {% endif %}
</script>
