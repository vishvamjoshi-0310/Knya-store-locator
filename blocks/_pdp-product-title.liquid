{%- assign heading_tag = block.settings.heading_tag | default: 'h1' -%}
{%- assign font_family = block.settings.font | default: 'Heebo-Regular' -%}
{%- case font_family -%}
  {%- when 'Heebo-Regular' -%}
    {%- assign font_class = 'heebo-regular' -%}
  {%- when 'Heebo-Medium' -%}
    {%- assign font_class = 'heebo-medium' -%}
  {%- when 'Heebo-SemiBold' -%}
    {%- assign font_class = 'heebo-semibold' -%}
  {%- when 'Heebo-Bold' -%}
    {%- assign font_class = 'heebo-bold' -%}
  {%- else -%}
    {%- assign font_class = 'heebo-regular' -%}
{%- endcase -%}
{% if closest.product == blank %}
  {% assign text = 'placeholders.product_title' | t %}
  {% assign product_title = '<' | append: heading_tag | append: ' class="product_title ' | append: font_class | append: '">' | append: text | append: '</' | append: heading_tag | append: '>' %}
  {% render 'text', fallback_text: product_title, block: block %}
{% elsif closest.product != blank %}
  {% assign product_title = '<' | append: heading_tag | append: ' class="product_title ' | append: font_class | append: '">' | append: closest.product.title | append: '</' | append: heading_tag | append: '>' %}
  {% render 'text', fallback_text: product_title, block: block %}
{% endif %}
<style>
    .product-title-group h1.product_title {
        line-height: clamp(32px, calc(34 * (100vw / 1440)), 42px);
        letter-spacing: .015em;
        color: #482f8f;
        font-size: clamp(18px,calc(24 * (100vw / 1440)),26px);
    }
    @media (max-width: 749px) {
      .product-title-group h1.product_title {
        font-size: clamp(22px, calc(24 * (100vw / 1440)), 26px);
        line-height: clamp(32px, calc(40 * (100vw / 1440)), 42px);
      }
    }
</style>
