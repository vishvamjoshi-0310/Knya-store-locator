{% style %}
    .superhero-lookbook__slider-item-{{ block.id }} {
        flex: 0 0 85%;
      }
  .superhero-lookbook__item-{{ block.id }} {
      position: relative;
      overflow: hidden;
    }
      .superhero-lookbook__image-wrapper-{{ block.id }} {
      position: relative;
      width: 100%;
      padding-bottom: 133%;
      overflow: hidden;
    }

      .superhero-lookbook__image-{{ block.id }} {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

      .superhero-lookbook__placeholder-{{ block.id }} {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: #f4f4f4;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .superhero-lookbook__placeholder-{{ block.id }} svg {
      width: 60%;
      height: 60%;
      opacity: 0.3;
    }

      .superhero-lookbook__button-{{ block.id }} {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%,-50%);
      padding: 12px 24px;
      background-color: {{ section.settings.button_background }};
      color: {{ section.settings.button_text_color }};
      text-decoration: none;
      border-radius: {{ section.settings.button_border_radius }}px;
      font-size: {{ section.settings.button_font_size }}px;
      font-weight: 600;
      letter-spacing: 0.5px;
      transition: all 0.3s ease;
      z-index: 2;
      display: inline-block;
      display: none;
    }

     .superhero-lookbook__image-{{ block.id }}:hover ~ .superhero-lookbook__button-{{ block.id }} {
       display: block;
     }

    .superhero-lookbook__button-{{ block.id }}:hover {
       background-color: {{ section.settings.button_hover_background }};
       color: {{ section.settings.button_hover_text_color }};
       border: 1px solid {{ section.settings.button_hover_text_color }};
       display: block;
    }

      .superhero-lookbook__label-{{ block.id }} {
      position: absolute;
      bottom: 20px;
      line-height: 1.2;
      right: 20px;
      color: {{ section.settings.label_color }};
      font-size: {{ section.settings.label_font_size }}px;
      z-index: 2;
    }

    @media screen and (max-width: 800px) {
        .superhero-lookbook__button-{{ block.id }} {
        display: block;
        padding: 10px 20px;
        font-size: {{ section.settings.button_font_size_mobile }}px;
      }

      .superhero-lookbook__label-{{ block.id }} {
        bottom: 16px;
        right: 16px;
        font-size: {{ section.settings.label_font_size_mobile }}px;
      }

    }
{% endstyle %}

{% assign current_image = block.settings.image_key %}
{% assign current_label = block.settings.label_key %}
{% assign current_button_url = block.settings.button_url_key %}

<div class="superhero-lookbook__slider-item-{{ block.id }}">
  <div class="superhero-lookbook__item-{{ block.id }}">
    <div class="superhero-lookbook__image-wrapper-{{ block.id }}">
      {% if current_image %}
        <img
          src="{{ current_image | image_url: width: 600 }}"
          alt="{{ current_image.alt | escape }}"
          class="superhero-lookbook__image-{{ block.id }}"
          loading="lazy"
          width="600"
          height="798"
        >
      {% else %}
        <div class="superhero-lookbook__placeholder-{{ block.id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}

      <a
        href="{{ current_button_url }}"
        class="superhero-lookbook__button-{{ block.id }} heebo-regular"
      >
        {{ section.settings.button_label }}
      </a>
      {% if current_label != blank %}
        <div class="superhero-lookbook__label-{{ block.id }} heebo-semibold">
          {{ current_label }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with Label",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_key",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "label_key",
      "label": "Label text"
    },
    {
      "type": "url",
      "id": "button_url_key",
      "label": "Button link"
    }
  ],
  "presets": [{ "name": "Label Image" }]
}
{% endschema %}
