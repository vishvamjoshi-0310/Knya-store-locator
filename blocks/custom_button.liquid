{% style %}
  .custom-button-{{ block.id }} {
    display: inline-block;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    border: none;
    letter-spacing: 0.6px;
  }

  .custom-button-{{ block.id }}:hover {
    background-color: {{ block.settings.hover_background_color }};
    color: {{ block.settings.hover_text_color }};
  }

  @media screen and (min-width: 750px) {
    .custom-button-{{ block.id }} {
      font-size: {{ block.settings.font_size_desktop }}px;
      padding: {{ block.settings.padding_vertical_desktop }}px {{ block.settings.padding_horizontal_desktop }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .custom-button-{{ block.id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
      padding: {{ block.settings.padding_vertical_mobile }}px {{ block.settings.padding_horizontal_mobile }}px;
    }
  }
{% endstyle %}

<a
  href="{{ block.settings.button_link }}"
  class="custom-button-{{ block.id }} heebo-medium"
  {{ block.shopify_attributes }}
>
  {{ block.settings.button_text }}
</a>

{% schema %}
{
  "name": "Custom button",
  "settings": [
    {
      "type": "header",
      "content": "Button content"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Click here"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#462d8c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "hover_background_color",
      "label": "Hover background color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 14
    },
    {
      "type": "header",
      "content": "Desktop sizing"
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_horizontal_desktop",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_vertical_desktop",
      "min": 5,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Vertical padding",
      "default": 14
    },
    {
      "type": "header",
      "content": "Mobile sizing"
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_vertical_mobile",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Vertical padding",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Custom button"
    }
  ],
  "tag": null
}
{% endschema %}