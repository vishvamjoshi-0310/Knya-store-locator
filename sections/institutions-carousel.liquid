{{ 'institutions-carousel.css' | asset_url | stylesheet_tag: preload: true }}

<div class="logo-slider-section">
  <div class="page-width-updated container">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subheading }}</p>
    <div class="logo-slider-wrapper" id="logoSlider">
      <div class="logo-slider-track" id="logoSliderTrack">
        {% comment %} First set of items {% endcomment %}
        {% for block in section.blocks %}
          {% if block.settings.image %}
            <div class="logo-slider-item">
              <picture>
                {%- if block.settings.image -%}

                  <!-- WebP Source -->
                  <source
                    type="image/webp"
                    srcset="
                      {{ block.settings.image | image_url: width: 300, format: 'webp' }} 300w,
                      {{ block.settings.image | image_url: width: 500, format: 'webp' }} 500w
                    "
                    sizes="(max-width: 600px) 300px, 500px"
                  >

                  <!-- Original Format Source (JPG/PNG) -->
                  <source
                    srcset="
                      {{ block.settings.image | image_url: width: 300 }} 300w,
                      {{ block.settings.image | image_url: width: 500 }} 500w
                    "
                    sizes="(max-width: 600px) 300px, 500px"
                  >

                  <!-- Fallback <img> -->
                  <img
                    src="{{ block.settings.image | image_url: width: 500 }}"
                    alt="Logo"
                    loading="lazy"
                    fetchpriority="low"
                    width="100"
                    height="auto"
                  >

                {%- endif -%}
              </picture>

            </div>
          {% endif %}
        {% endfor %}
        {% comment %} Duplicate set for seamless loop {% endcomment %}
        {% for block in section.blocks %}
          {% if block.settings.image %}
            <div class="logo-slider-item">
                            <picture>
                {%- if block.settings.image -%}

                  <!-- WebP Source -->
                  <source
                    type="image/webp"
                    srcset="
                      {{ block.settings.image | image_url: width: 300, format: 'webp' }} 300w,
                      {{ block.settings.image | image_url: width: 500, format: 'webp' }} 500w
                    "
                    sizes="(max-width: 600px) 300px, 500px"
                  >

                  <!-- Original Format Source (JPG/PNG) -->
                  <source
                    srcset="
                      {{ block.settings.image | image_url: width: 300 }} 300w,
                      {{ block.settings.image | image_url: width: 500 }} 500w
                    "
                    sizes="(max-width: 600px) 300px, 500px"
                  >

                  <!-- Fallback <img> -->
                  <img
                    src="{{ block.settings.image | image_url: width: 500 }}"
                    alt="Logo"
                    loading="lazy"
                    fetchpriority="low"
                    width="500"
                    height="auto"
                  >

                {%- endif -%}
              </picture>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const institution_slider = document.getElementById('logoSlider');
    const track = document.getElementById('logoSliderTrack');

    if (!track) return;

    // Pause animation on hover
    institution_slider.addEventListener('mouseenter', function () {
      track.style.animationPlayState = 'paused';
    });

    institution_slider.addEventListener('mouseleave', function () {
      track.style.animationPlayState = 'running';
    });
  });
</script>

{% schema %}
{
  "name": "institutions-carousel",
  "class": "institutions-carousel-parent",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Institutions we have served"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "We’ve suited up the best"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Institutions Carousel"
    }
  ]
}
{% endschema %}
