{{ 'faq-accordion-stylesheet.css' | asset_url | stylesheet_tag }}
<script src="{{ 'faq-accordion-javascript.js' | asset_url }}" defer="defer"></script>

<div class="font-heebo-regular faq-container">
  {% if section.settings.heading %}
    <h2>{{ section.settings.heading }}</h2>
  {% endif %}
  {% for block in section.blocks %}
    {% if block.settings.question != blank and block.settings.answer != blank %}
      <div class="faq-item" onclick="toggleFAQ(this)">
        <div class="faq-question">
          <span>{{ block.settings.question }}</span>
          <span class="icon icon-plus">{{ 'icon-plus.svg' | inline_asset_content }}</span>
          <span class="icon icon-minus">{{ 'icon-minus.svg' | inline_asset_content }}</span>
        </div>
        <div class="faq-answer">
          <p>{{ block.settings.answer }}</p>
        </div>
      </div>
    {% endif %}
  {% endfor %}
</div>

{% schema %}
{
  "name": "FAQ Accordion",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "FAQs"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Accordion",
    }
  ]
}
{% endschema %}