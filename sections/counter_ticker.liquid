{{ 'counter_ticker.css' | asset_url | stylesheet_tag: preload: true }}

<div class="count-ticker-section">
  <div class="count-ticker-text-container">
    <h2 class="count-ticker-heading">{{ section.settings.heading }}</h2>
    <p class="count-ticker-subheading">{{ section.settings.subheading }}</p>
  </div>
  <div class="count-ticker-block-container">
    {% content_for 'blocks' %}
  </div>
</div>

<script src="{{ 'counter_ticker.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "count-ticker-section",
  "class": "count-ticker-section-parent",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "blocks": [
    {
      "type": "_counter_ticker"
    }
  ],
  "presets": [
    {
      "name": "Count Ticker Section"
    }
  ]
}
{% endschema %}
