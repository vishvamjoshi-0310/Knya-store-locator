<link
  rel="stylesheet"
  href="{{ 'bulk_order.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

<div class="bulk-order-steps">
  <div class="bulk-order-container">
    <h2 class="bulk-order-heading">{{ section.settings.heading }}</h2>
    <p class="bulk-order-subheading">{{ section.settings.subheading }}</p>

    <div class="steps-wrapper">
      <div class="bulk-order-border"></div>
        {% content_for 'blocks' %}

    </div>

    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" class="order-button">
        {{ section.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

<script src="{{ 'bulk_order.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Bulk Order Steps",
  "class": "bulk-order-steps-parent",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bulk Ordering Made Simple"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Fill out the form, and we'll take care of the rest."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Start Your Order Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "_steps",
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Bulk Order Steps",
      "category": "Custom"
    }
  ]
}
{% endschema %}
